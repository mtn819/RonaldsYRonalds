@{
}

@model RonaldsYRonalds.Models.TicketModel

@{
    ViewData["Title"] = "Process Ticket";
}

<h1>Process</h1>

<div>
    <h4>Ticket</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.UserName)
        </dt
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UserName)
        </dd>
    </dl>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
    </dl>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Vin)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Vin)
        </dd>
    </dl>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IncidentDescription)
        </dt>
        <dd class="col-sm-10 mw-50ch text-wrap text-break">
            @Html.DisplayFor(model => model.IncidentDescription)
        </dd>
    </dl>
</div>

<div>
    <form asp-action="Fulfill" method="post" class="mb-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-success">
            Fulfill
        </button>
    </form>
    <form asp-action="Reject" method="post" class="mb-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">
            Reject
        </button>
    </form>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
